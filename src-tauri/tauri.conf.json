{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FreeLip",
  "version": "0.1.0",
  "identifier": "local.freelip.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FreeLip Dev Shell",
        "width": 900,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
