{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freelip.local/schemas/llm_rerank_request.schema.json",
  "title": "LlmRerankRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "session_id",
    "context_text",
    "candidates",
    "dictionary_terms",
    "max_candidates"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "request_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "context_text": { "type": "string", "maxLength": 2048 },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "dictionary_terms": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/dictionary_term" }
    },
    "max_candidates": { "type": "integer", "minimum": 1, "maximum": 5 }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "rank",
        "text",
        "score",
        "source",
        "is_auto_insert_eligible"
      ],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "rank": { "type": "integer", "minimum": 1, "maximum": 5 },
        "text": { "type": "string", "minLength": 1, "maxLength": 256 },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": {
          "type": "string",
          "enum": ["vsr", "cnvsrc2025", "dictionary", "llm_rerank", "manual"]
        },
        "is_auto_insert_eligible": { "type": "boolean" }
      }
    },
    "dictionary_term": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "weight", "tags"],
      "properties": {
        "surface": { "type": "string", "minLength": 1, "maxLength": 128 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 },
          "uniqueItems": true,
          "maxItems": 16
        }
      }
    }
  }
}
