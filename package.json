{
  "name": "freelip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "tauri": "tauri",
    "test": "npm run test:contracts",
    "test:contracts": "python3 -m pytest python/tests/test_contract_schema.py -q",
    "test:ui": "node --experimental-strip-types scripts/test_ui.ts",
    "test:debug-bundle": "node scripts/test_debug_bundle.mjs",
    "sidecar:debug:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/run_sidecar_debug.ps1",
    "bundle:debug:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/build_debug_bundle.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
