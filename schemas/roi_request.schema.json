{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freelip.local/schemas/roi_request.schema.json",
  "title": "RoiRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "session_id",
    "source",
    "roi",
    "quality_flags",
    "requested_at_ms"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "started_at_ms"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["camera", "public_video", "fixture"]
        },
        "device_id_hash": {
          "type": "string",
          "maxLength": 128
        },
        "started_at_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "roi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_ref",
        "format",
        "width",
        "height",
        "fps",
        "frame_count",
        "duration_ms"
      ],
      "properties": {
        "local_ref": {
          "type": "string",
          "pattern": "^local://",
          "maxLength": 512
        },
        "format": {
          "type": "string",
          "enum": ["grayscale_u8", "rgb_u8", "tensor_f32_nchw"]
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 120
        },
        "frame_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1200
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30000
        }
      }
    },
    "quality_flags": {
      "$ref": "#/$defs/quality_flags"
    },
    "requested_at_ms": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "quality_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "face_found",
        "mouth_landmarks_found",
        "crop_bounds_valid",
        "blur_ok",
        "brightness_ok",
        "pose_ok",
        "occlusion_ok",
        "landmark_confidence",
        "rejection_reasons"
      ],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "face_found": { "type": "boolean" },
        "mouth_landmarks_found": { "type": "boolean" },
        "crop_bounds_valid": { "type": "boolean" },
        "blur_ok": { "type": "boolean" },
        "brightness_ok": { "type": "boolean" },
        "pose_ok": { "type": "boolean" },
        "occlusion_ok": { "type": "boolean" },
        "landmark_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rejection_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "face_not_found",
              "mouth_landmarks_missing",
              "crop_bounds_invalid",
              "blur_too_high",
              "brightness_out_of_range",
              "pose_out_of_range",
              "mouth_occluded"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
